# ─────────────────────────────────────────────────────────────────
# Fleet Operating System — Environment Variables
# Copy this file to .env and fill in your values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
# Credentials used by both the db service and the API connection string.
POSTGRES_USER=fleetuser
POSTGRES_PASSWORD=fleetpass
POSTGRES_DB=fleetdb

# Full connection string consumed by the FastAPI backend.
# When running via Docker Compose, the host is "db" (the service name).
# When running the API locally outside Docker, use "localhost".
DATABASE_URL=postgresql://fleetuser:fleetpass@db:5432/fleetdb

# ── API ───────────────────────────────────────────────────────────
# Port the FastAPI server listens on inside the container.
API_PORT=8000

# Logging level: debug | info | warning | error | critical
LOG_LEVEL=info

# Local development fleet grouping label. The value is arbitrary, but it must
# be consistent for the live map, Geotab ingestion, and simulator ingestion.
DEV_FLEET_ID=8

# ── FMCSA / Socrata ───────────────────────────────────────────────
# Company Census JSON resource used for bulk carrier ingestion.
FMCSA_COMPANY_CENSUS_URL=https://data.transportation.gov/resource/az4n-8mr2.json

# Daily diff JSON resource placeholder. This endpoint is currently blocked
# because Socrata reports no row/column access for this non-tabular table.
FMCSA_DAILY_DIFF_URL=https://data.transportation.gov/resource/6qg9-x4f8.json

# Number of Socrata records to fetch per page.
FMCSA_PAGE_SIZE=50000

# ── Geotab ───────────────────────────────────────────────────────
# MyGeotab demo database credentials for DeviceStatusInfo ingestion.
GEOTAB_DATABASE=
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
GEOTAB_POLL_INTERVAL_SECONDS=10

# ── DAT Load Board Integration ───────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
DAT_PROVIDER_MODE=mock
DAT_ENVIRONMENT=staging
DAT_IDENTITY_BASE_URL=https://identity.api.dat.com
# Optional explicit freight host override. Leave blank to use DAT_ENVIRONMENT.
DAT_FREIGHT_BASE_URL=
DAT_ORG_TOKEN_PATH=/access/v1/token/organization
DAT_USER_TOKEN_PATH=/access/v1/token/user
DAT_LOAD_SEARCH_PATH=/search/v1/loads
DAT_LOAD_SEARCH_RESULTS_PATH=/search/v1/loads/{search_id}/results
DAT_ORGANIZATION_TOKEN_HEADER=x-dat-organization-token
DAT_SEARCH_POLL_ATTEMPTS=6
DAT_SEARCH_POLL_INTERVAL_SECONDS=1
DAT_POLL_INTERVAL_SECONDS=60
DAT_RATE_LIMIT_PER_MINUTE=60
DAT_MAX_RETRIES=3
DAT_CIRCUIT_BREAKER_THRESHOLD=3
DAT_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# ── Truckstop Load Board Integration ─────────────────────────────
TRUCKSTOP_PROVIDER_MODE=mock
TRUCKSTOP_ENVIRONMENT=staging
# Optional explicit SOAP host override. Leave blank to use TRUCKSTOP_ENVIRONMENT.
TRUCKSTOP_LOADSEARCH_BASE_URL=
TRUCKSTOP_LOADSEARCH_PATH=/v13/Searching/LoadSearch.svc
TRUCKSTOP_LOADSEARCH_SOAP_ACTION=http://webservices.truckstop.com/v12/ILoadSearch/GetLoadSearchResults
TRUCKSTOP_POLL_INTERVAL_SECONDS=60
TRUCKSTOP_RATE_LIMIT_PER_MINUTE=60
TRUCKSTOP_MAX_RETRIES=3
TRUCKSTOP_CIRCUIT_BREAKER_THRESHOLD=3
TRUCKSTOP_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# ── CORS ─────────────────────────────────────────────────────────
# Origin(s) allowed to make cross-origin requests to the API.
# Set to the URL where the frontend is served during local development.
FRONTEND_URL=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────
# Base URL the Next.js app uses to call the API.
# Must be reachable from the browser (not the Docker network).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Firebase ─────────────────────────────────────────────────────
# Firebase web app configuration. These NEXT_PUBLIC_ values are shipped to
# the browser and are not secret, but fill them in from your own Firebase
# project console before running.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

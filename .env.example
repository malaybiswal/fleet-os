# ─────────────────────────────────────────────────────────────────
# Fleet Operating System — Environment Variables
# Copy this file to .env and fill in your values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
# Credentials used by both the db service and the API connection string.
POSTGRES_USER=fleetuser
POSTGRES_PASSWORD=fleetpass
POSTGRES_DB=fleetdb

# Full connection string consumed by the FastAPI backend.
# When running via Docker Compose, the host is "db" (the service name).
# When running the API locally outside Docker, use "localhost".
DATABASE_URL=postgresql://fleetuser:fleetpass@db:5432/fleetdb

# ── API ───────────────────────────────────────────────────────────
# Port the FastAPI server listens on inside the container.
API_PORT=8000

# Logging level: debug | info | warning | error | critical
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────
# Origin(s) allowed to make cross-origin requests to the API.
# Set to the URL where the frontend is served during local development.
FRONTEND_URL=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────
# Base URL the Next.js app uses to call the API.
# Must be reachable from the browser (not the Docker network).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Motive Telematics Integration (OAuth 2.0) ────────────────────
# Client ID and Secret from your app's Configuration tab in the Motive
# developer portal (developer-docs.gomotive.com → +Create App).
MOTIVE_CLIENT_ID=
MOTIVE_CLIENT_SECRET=
#
# Access token and refresh token are obtained once by completing the OAuth
# authorization code flow (see docs/motive-oauth-setup.md). Paste the values
# here after the initial authorization. The client auto-refreshes the access
# token using the refresh token before it expires (TTL: 2 hours).
MOTIVE_ACCESS_TOKEN=
MOTIVE_REFRESH_TOKEN=

# ── Data Ingestion Scheduler ─────────────────────────────────────
# Set to true to enable background polling from external providers.
# Must also set at least one provider API key above.
INGESTION_ENABLED=false
INGESTION_INTERVAL_MINUTES=5
